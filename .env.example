# 多图床上传小工具
# 将本文件复制为项目根目录下的 ".env" 后，再按需填写。
# 环境变量加载优先级：
# 1. 系统环境变量
# 2. .env.local
# 3. .env

# ------------------------------------------------------------------------------
# 服务端
# ------------------------------------------------------------------------------

# 本地开发服务器端口。
PORT=8000

# 可选。用于保护当前 Node 服务下所有 /api/* 上传接口的访问令牌。
# 设置后，客户端请求需要携带以下任一请求头：
# - Authorization: Bearer <AUTH_TOKEN>
# - X-Auth-Token: <AUTH_TOKEN>
AUTH_TOKEN=

# AUTH_TOKEN 的兼容别名。新配置建议优先使用 AUTH_TOKEN。
# IMG_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Lsky Pro+ 多实例配置
# ------------------------------------------------------------------------------

# 推荐使用：通过一个 JSON 数组定义多个 Lsky 服务。
# 说明：
# 1. 这里必须写成单行 JSON
# 2. key 会作为接口标识和路由的一部分，建议只用英文字母、数字、短横线
# 3. name 是前端显示名称
# 4. baseUrl 填站点根地址即可，项目会自动推导为 {baseUrl}/api/v2/upload
# 5. token 留空时是否允许上传，取决于实例是否开启游客上传
#
# 示例：
# LSKY_PRO_SERVICES=[{"key":"main","name":"Lsky 主图床","baseUrl":"https://img-a.example.com","token":"token-a","storageId":"1"},{"key":"backup","name":"Lsky 备份图床","baseUrl":"https://img-b.example.com","token":"token-b","storageId":"2","albumId":"5","isPublic":true,"removeExif":false}]
#
# 可用字段：
# - key
# - name
# - subtitle
# - accent
# - enabled
# - baseUrl
# - apiUrl
# - token
# - storageId
# - albumId
# - expiredAt
# - tags               可为数组或逗号分隔字符串
# - isPublic
# - removeExif
# - intro
# - maxFileSizeBytes
# - accepts            例如 ["image/*"] 或 ["image/*","video/*"]
LSKY_PRO_SERVICES=

# ------------------------------------------------------------------------------
# Lsky Pro+ 单实例兼容配置
# ------------------------------------------------------------------------------

# 如果你只需要一个 Lsky 服务，也可以继续使用下面这组旧写法。
# 当 LSKY_PRO_SERVICES 已填写时，优先使用多实例配置。

# 显式启用或禁用 Lsky Pro+ 选项卡。
# 留空时会在设置了 LSKY_PRO_BASE_URL 或 LSKY_PRO_API_URL 后自动启用。
LSKY_PRO_ENABLED=

# 单实例的接口 key。会影响路由地址，例如：
# /api/lsky-upload/default
LSKY_PRO_KEY=default

# 前端显示名称。
LSKY_PRO_NAME=Lsky Pro+

# 前端副标题。
LSKY_PRO_SUBTITLE=Runtime config

# 前端标签颜色。
LSKY_PRO_ACCENT=#0f766e

# 推荐填写：你的 Lsky 站点根地址。
# 项目会自动推导上传接口地址：
#   {LSKY_PRO_BASE_URL}/api/v2/upload
# 示例：
#   https://img.example.com
LSKY_PRO_BASE_URL=

# 可选。当你的实例接口前缀不是 /api/v2 时，可直接填写完整 API 基础地址。
# 示例：
#   https://img.example.com/api/v2
LSKY_PRO_API_URL=

# 可选。服务端代理请求 Lsky 时使用的 Bearer Token。
# 推荐权限：upload:write
# 如果留空，是否允许上传取决于你的 Lsky 实例是否开启游客上传。
LSKY_PRO_TOKEN=

# 可选。以下为上传到 /api/v2/upload 时附带的默认参数。

# 存储策略 ID。
LSKY_PRO_STORAGE_ID=

# 相册 ID。
LSKY_PRO_ALBUM_ID=

# 过期时间，原样传给 Lsky。
# 请按照你的实例/API 要求填写正确格式。
LSKY_PRO_EXPIRED_AT=

# 逗号分隔的标签列表。代理层会转换为重复的 tags[] 字段。
# 示例：
# screenshot,docs,release
LSKY_PRO_TAGS=

# 是否公开可见。
# 支持值：true / false / 1 / 0 / yes / no / on / off
LSKY_PRO_IS_PUBLIC=

# 是否在存储前移除 EXIF 元数据。
# 支持值：true / false / 1 / 0 / yes / no / on / off
LSKY_PRO_REMOVE_EXIF=

# 可选。图片描述或简介文本。
LSKY_PRO_INTRO=

# 可选。用于前端界面展示的大小提示，单位为字节。
# 这个值只影响前端提示，本身不会自动限制服务端上传大小。
LSKY_PRO_MAX_FILE_SIZE_BYTES=

# 可选。允许的文件类型，逗号分隔。
# 默认值为 image/*
# 示例：
# image/*
# image/*,video/*
LSKY_PRO_ACCEPTS=

# ------------------------------------------------------------------------------
# 兼容旧变量名
# ------------------------------------------------------------------------------
# 以下旧变量名目前仍然兼容，但为了统一，新的配置建议优先使用上面的
# LSKY_PRO_* 命名。
#
# LSKY_PRO_URL=
# LSKY_BASE_URL=
# LSKY_TOKEN=
# LSKY_STORAGE_ID=
# LSKY_ALBUM_ID=
